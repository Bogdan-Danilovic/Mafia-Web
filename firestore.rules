rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Postojeće kolekcije ───────────────────────────────────────────────
    match /rooms/{code} {
      allow read: if true;
      // CREATE: any authed user (incl. anonymous guests) may open a room. The
      // premiumUntil guard MUST NOT run on create — `resource` is null there, so
      // request.resource.data.diff(resource.data) errors and denies every write.
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && !('premiumUntil' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Profili ───────────────────────────────────────────────────────────
    // Guests use Firebase Anonymous Auth, so request.auth.uid is ALWAYS present
    // (guest or logged-in). Rules stay auth-gated — we deliberately do NOT use a
    // public "document id == request.resource.data.id" write rule. A player may
    // read any profile (leaderboard / friends) but write only their own document.
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !('premiumUntil' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Username registar ─────────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Game history ──────────────────────────────────────────────────────
    match /gameHistory/{uid}/games/{gameId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Zahtjevi za prijateljstvo ─────────────────────────────────────────
    // Only the sender and recipient may read/write their own requests.
    // Query in subscribeToFriendRequests filters by `to == uid`, so the rule
    // must allow reads where resource.data.to == request.auth.uid.
    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.to == request.auth.uid
          || resource.data.from == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.to == request.auth.uid
          || resource.data.from == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.to == request.auth.uid
          || resource.data.from == request.auth.uid);
    }

    // ── Stats / donations — samo admin SDK ───────────────────────────────
    match /stats/donations {
      allow read: if true;
      allow write: if false;
    }
  }
}
